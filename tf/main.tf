terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }

  backend "s3" {
    # Configure this after creating an S3 bucket for terraform state
    # bucket = "your-terraform-state-bucket"
    # key    = "jf/terraform.tfstate"
    # region = "us-east-1"
    # Uncomment the above lines and run 'terraform init' to use S3 backend
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Project     = var.project_name
      Environment = var.environment
      ManagedBy   = "Terraform"
    }
  }
}

# Data sources
data "aws_availability_zones" "available" {
  state = "available"
}

data "aws_caller_identity" "current" {}

